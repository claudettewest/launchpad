{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch App (port 3411)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/server.js",
      "cwd": "${workspaceFolder}",
      "env": {
        "PORT": "3411"
      },
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "Launch pad running at (http://localhost:[0-9]+)",
        "uriFormat": "%s",
        "action": "openExternally"
      },
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
